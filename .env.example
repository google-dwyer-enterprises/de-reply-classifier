# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` — it contains live API keys.

# --- Prospeo (lead scraper) ---
# Get your API key from https://prospeo.io → Dashboard → API
PROSPEO_API_KEY=

# --- Anthropic (Claude Haiku for classifier + agency filter) ---
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Supabase (Postgres) ---
# Project URL (https://<project-ref>.supabase.co)
SUPABASE_URL=
# Service-role key — Settings → API → service_role secret
SUPABASE_KEY=
# DB password — Settings → Database → connection string
SUPABASE_DB_PASSWORD=
# Optional override of the full Postgres connection string:
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<pw>@<host>:5432/postgres?sslmode=require
# Optional pooler host override (defaults to aws-1-ap-northeast-1.pooler.supabase.com):
# SUPABASE_DB_HOST=

# --- Instantly (used by other modules; not required for the scraper) ---
INSTANTLY_API_KEY=
