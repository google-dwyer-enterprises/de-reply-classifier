# Lead Reviewer Flask app — Jam's CRM-style review surface that replaces
# the NocoDB Submit-a-request form and per-batch review views.
#
# Deployed as a SEPARATE Railway service alongside the worker. Same Git
# repo; the worker still uses Dockerfile.worker.
#
# Build:   docker build -f Dockerfile.web -t lead-reviewer .
# Run:     docker run -p 5000:5000 --env-file .env lead-reviewer

FROM python:3.12-slim

WORKDIR /app

# psycopg2 needs libpq
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Railway provides $PORT. Two workers is enough for Jam's usage.
CMD gunicorn -w 2 -b 0.0.0.0:${PORT:-5000} --timeout 120 --graceful-timeout 30 --access-logfile - --error-logfile - app:app
