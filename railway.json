{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python run.py refresh && python run.py refresh-followup-patterns",
    "restartPolicyType": "NEVER",
    "cronSchedule": "0 9 * * *"
  }
}
